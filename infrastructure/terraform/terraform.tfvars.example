# Copy this to terraform.tfvars and fill in your values
# DO NOT commit terraform.tfvars to git!

aws_region    = "ca-central-1"
project_name  = "goaliefinder"
environment   = "production"

# RDS PostgreSQL password — choose a strong one
db_password = "CHANGE_ME_strong_password_123!"

# db.t3.micro = Free Tier eligible, db.t3.medium = production
db_instance_class = "db.t3.micro"

# JWT secret — generate with: openssl rand -base64 64
jwt_secret = "CHANGE_ME_generate_a_64_char_random_string_here"

# Domain name — leave empty to skip DNS/SSL setup
domain_name = ""

# ECS settings
api_cpu       = 512   # 0.5 vCPU
api_memory    = 1024  # 1 GB
desired_count = 1     # number of running tasks
